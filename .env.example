# 允许局域网内其他设备访问（pnpm dev 监听 0.0.0.0）
ALLOW_LAN_ACCESS=true

# 访问密码（legacy 模式）。设置后需要登录才能访问，登录后才有 session。
# 用户名固定为 admin，密码由该变量决定。
ADMIN_PASSWORD=your_password_here

# 持久化 session（默认 true）。关闭后浏览器关闭即失效。
# PERSIST_SESSION=true

# 托管账户模式（managed），需要 Redis 与 AUTH_SECRET。
# 启用后可通过设置页管理多账户、角色与权限。
# AUTH_SECRET=your_random_secret_at_least_32_chars
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_redis_token

# 传统多账户配置（与 ADMIN_PASSWORD 互斥，二选一）。
# 格式：密码:显示名称:角色:额外权限,...
# ACCOUNTS=pass1:Admin:super_admin,pass2:Viewer:viewer
